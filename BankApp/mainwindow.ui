 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>900</width>
    <height>674</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Bank App</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* GLOBAL */
QWidget {
    background-color: #0f172a;
    color: #e2e8f0;
    font-family: 'Segoe UI';
    font-size: 14px;
}

/* LEFT PANEL */
QFrame#leftPanel {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #3b82f6,
        stop:1 #9333ea
    );
    border-radius: 15px;
}

QLabel#appTitle {
    font-size: 32px;
    font-weight: bold;
    color: white;
}

QLabel#tagline {
    font-size: 14px;
    color: #e0e7ff;
}

/* LOGIN CARD */
QFrame#loginCard {
    background-color: #1e293b;
    border-radius: 20px;
    padding: 25px;
}

/* TITLE */
QLabel#loginTitle {
    font-size: 22px;
    font-weight: bold;
    margin-bottom: 10px;
}

/* INPUTS */
QLineEdit {
    background-color: #0f172a;
    border: 2px solid #334155;
    border-radius: 10px;
    padding: 10px;
}

QLineEdit:focus {
    border: 2px solid #3b82f6;
}

/* BUTTONS */
QPushButton {
    background-color: #3b82f6;
    border-radius: 10px;
    padding: 10px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #2563eb;
}

QPushButton:pressed {
    background-color: #1d4ed8;
}

/* ADMIN BUTTON SPECIAL */
QPushButton#adminBtn {
    background-color: #9333ea;
}

QPushButton#adminBtn:hover {
    background-color: #7e22ce;
}</string>
  </property>
  <widget class="QWidget" name="centralwidget">
